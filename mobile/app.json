{
  "expo": {
    "name": "A Beauty Spa",
    "slug": "abeauty-medspa",
    "version": "1.0.0",
    "scheme": "abeautymedspa",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.abeautymedspa.app",
      "buildNumber": "2",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "프로필 사진을 업로드하기 위해 사진에 접근합니다.",
        "NSCameraUsageDescription": "프로필 사진을 촬영하기 위해 카메라에 접근합니다.",
        "NSLocationWhenInUseUsageDescription": "가장 가까운 클리닉을 찾기 위해 위치에 접근합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.abeautymedspa.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7b651974-9130-4001-bc89-cfccfbad35b0"
      }
    },
    "owner": "parkyoungsun",
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
